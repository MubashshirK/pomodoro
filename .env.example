# --- Database (Neon Postgres) ---
# Get these from https://console.neon.tech → your project → Connection details.
# - DATABASE_URL: use the POOLED connection string (hostname contains "-pooler").
# - DIRECT_URL: use the direct (non-pooled) connection string. Used for migrations.
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/neondb?sslmode=require"

# --- Auth.js v5 ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-openssl-rand-base64-32"
# Set to your deployed URL in production, http://localhost:3000 for dev.
AUTH_URL="http://localhost:3000"
