# Copy to .env for local development.
# On Vercel, POSTGRES_URL and POSTGRES_PRISMA_URL are auto-set by the
# Vercel Postgres integration. IRON_SESSION_PASSWORD must be set manually.
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/pomodoro
IRON_SESSION_PASSWORD=replace-with-32-plus-character-random-string-please
NODE_ENV=development
